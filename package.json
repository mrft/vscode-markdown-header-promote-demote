{
  "name": "markdown-header-promote-demote",
  "displayName": "Markdown Header Promote/Demote",
  "description": "Promote and demote markdown headers while preserving the relative structure of subsections.",
  "version": "0.1.0",
  "publisher": "mrft",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownStructure.promote",
        "title": "Markdown: Promote Headers"
      },
      {
        "command": "markdownStructure.demote",
        "title": "Markdown: Demote Headers"
      }
    ],
    "configuration": {
      "title": "Markdown Header Promote/Demote",
      "properties": {
        "markdownStructure.updateNumbering": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update numeric heading prefixes (e.g. 1.2.3) across the entire document after promoting or demoting headers."
        }
      }
    },
    "keybindings": [
      {
        "command": "markdownStructure.promote",
        "key": "shift+tab",
        "when": "editorTextFocus && editorLangId == markdown && markdownStructure.onHeaderLine && !inlineSuggestionVisible"
      },
      {
        "command": "markdownStructure.demote",
        "key": "tab",
        "when": "editorTextFocus && editorLangId == markdown && markdownStructure.onHeaderLine && !inlineSuggestionVisible"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "preadd_to_vscode": "npm install && npm run compile",
    "add_to_vscode": "vsce package && code --install-extension markdown-header-promote-demote-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.0.0"
  }
}
